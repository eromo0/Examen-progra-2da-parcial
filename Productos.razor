# Examen-progra-2da-parcial@page "/productos"
@rendermode InteractiveServer

<h3>
    <span class="bi bi-box-seam icon"></span>
    Productos
</h3>

<!-- FORMULARIO SIEMPRE VISIBLE -->
<div class="mb-3">
    <label>No. Inventario:</label>
    <input type="number" class="form-control" @bind="inventario" />
</div>

<div class="mb-3">
    <label>Nombre:</label>
    <input class="form-control" @bind="nombre" maxlength="200" />
</div>

<div class="mb-3">
    <label>Departamento:</label>
    <select class="form-control" @bind="departamento">
        <option value="">Selecciona</option>
        <option>Frutas</option>
        <option>Verduras</option>
        <option>Lácteos</option>
    </select>
</div>

@if (!modoEdicion)
{
    <button class="btn btn-primary" @onclick="Guardar">Guardar</button>
}
else
{
    <button class="btn btn-success me-2" @onclick="Actualizar">Actualizar</button>
    <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
}

<button class="btn btn-info ms-2" @onclick="VerExistencias">Existencias</button>
<button class="btn btn-secondary ms-2" @onclick="VolverListado">Listado</button>

@if (!string.IsNullOrEmpty(error))
{
    <p class="text-danger mt-2">@error</p>
}


@if (!vistaExistencias)
{

    @if (productos.Count > 0)
    {
        <table class="table mt-4">
            <thead>
                <tr>
                    <th>Inventario</th>
                    <th>Nombre</th>
                    <th>Departamento</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in productos)
                {
                    <tr>
                        <td>@p.Inventario</td>
                        <td>@p.Nombre</td>
                        <td>@p.Departamento</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1"
                                    @onclick="() => Editar(p)">
                                Editar
                            </button>
                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => Eliminar(p)">
                                Eliminar
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}
else
{

    <h5 class="mt-4">Existencias por Departamento</h5>

    <ul>
        <li>Frutas: @Contar("Frutas")</li>
        <li>Verduras: @Contar("Verduras")</li>
        <li>Lácteos: @Contar("Lácteos")</li>
    </ul>
}

@code {
    int inventario;
    string nombre = "";
    string departamento = "";
    string error = "";

    bool modoEdicion = false;
    bool vistaExistencias = false;

    Producto productoEditando;

    List<Producto> productos = new();

    void Guardar()
    {
        error = "";

        if (inventario <= 0 || string.IsNullOrWhiteSpace(nombre) || string.IsNullOrWhiteSpace(departamento))
        {
            error = "Datos inválidos";
            return;
        }

        if (productos.Any(p => p.Inventario == inventario))
        {
            error = "El número de inventario ya existe";
            return;
        }

        productos.Add(new Producto
        {
            Inventario = inventario,
            Nombre = nombre,
            Departamento = departamento
        });

        Limpiar();
    }

    void Eliminar(Producto p)
    {
        productos.Remove(p);
    }

    void Editar(Producto p)
    {
        modoEdicion = true;
        productoEditando = p;

        inventario = p.Inventario;
        nombre = p.Nombre;
        departamento = p.Departamento;
    }

    void Actualizar()
    {
        error = "";

        if (inventario <= 0 || string.IsNullOrWhiteSpace(nombre) || string.IsNullOrWhiteSpace(departamento))
        {
            error = "Datos inválidos";
            return;
        }

        if (productos.Any(p => p.Inventario == inventario && p != productoEditando))
        {
            error = "El número de inventario ya existe";
            return;
        }

        productoEditando.Inventario = inventario;
        productoEditando.Nombre = nombre;
        productoEditando.Departamento = departamento;

        modoEdicion = false;
        productoEditando = null;

        Limpiar();
    }

    void Cancelar()
    {
        modoEdicion = false;
        productoEditando = null;
        Limpiar();
    }

    void VerExistencias()
    {
        vistaExistencias = true;
    }

    void VolverListado()
    {
        vistaExistencias = false;
    }

    int Contar(string dep)
    {
        return productos.Count(p => p.Departamento == dep);
    }

    void Limpiar()
    {
        inventario = 0;
        nombre = "";
        departamento = "";
        error = "";
    }

    class Producto
    {
        public int Inventario { get; set; }
        public string Nombre { get; set; }
        public string Departamento { get; set; }
    }
}
